<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏃 ورزش | رهیلا</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:Arial;background:radial-gradient(circle at center,#0a1a1a,#1a4a4a,#66ccaa);color:#fff;text-align:center;padding:15px;min-height:100vh}
        .header{background:rgba(255,255,255,.08);backdrop-filter:blur(20px);border-radius:25px;padding:20px;margin-bottom:15px}
        .header h1{color:#ffd700;font-size:22px}
        .back-btn{display:inline-block;background:rgba(255,255,255,.15);color:#fff;padding:8px 20px;border-radius:20px;text-decoration:none;margin:10px 0;font-size:14px}
        .section-title{color:#ffd700;font-size:18px;margin:20px 0 10px}
        .grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
        .card{background:rgba(255,255,255,.05);border-radius:12px;padding:15px 8px;border:1px solid rgba(255,255,255,.1)}
        .card:active{background:rgba(255,215,0,.2)}
        .card .emoji{font-size:28px}
        .card h3{font-size:10px;color:#ffd700;margin-top:5px}
    </style>
</head>
<body>
    <div class="header"><h1>🏃 ورزش و تناسب اندام</h1></div>
    <a href="index.html" class="back-btn">🔙 برگشت</a>
    <div class="section-title">💪 بدنسازی</div>
    <div class="grid">
        <div class="card"><div class="emoji">💪</div><h3>برنامه مبتدی</h3></div>
        <div class="card"><div class="emoji">🏋️</div><h3>تمرین سینه</h3></div>
        <div class="card"><div class="emoji">🦵</div><h3>تمرین پا</h3></div>
        <div class="card"><div class="emoji">💪</div><h3>تمرین بازو</h3></div>
        <div class="card"><div class="emoji">🦾</div><h3>تمرین سرشانه</h3></div>
        <div class="card"><div class="emoji">🏋️</div><h3>کراسفیت</h3></div>
    </div>
    <div class="section-title">🏃 هوازی</div>
    <div class="grid">
        <div class="card"><div class="emoji">🏃</div><h3>دویدن</h3></div>
        <div class="card"><div class="emoji">🕺</div><h3>زومبا</h3></div>
        <div class="card"><div class="emoji">🚴</div><h3>دوچرخه‌سواری</h3></div>
        <div class="card"><div class="emoji">🏊</div><h3>شنا</h3></div>
        <div class="card"><div class="emoji">⛷️</div><h3>اسکی</h3></div>
        <div class="card"><div class="emoji">🛼</div><h3>اسکیت</h3></div>
    </div>
    <div class="section-title">🧘 آرامش</div>
    <div class="grid">
        <div class="card"><div class="emoji">🧘</div><h3>یوگا</h3></div>
        <div class="card"><div class="emoji">😌</div><h3>مدیتیشن</h3></div>
        <div class="card"><div class="emoji">🤸</div><h3>پیلاتس</h3></div>
    </div>
    <div class="section-title">⚽ ورزش‌ها</div>
    <div class="grid">
        <div class="card"><div class="emoji">⚽</div><h3>فوتبال</h3></div>
        <div class="card"><div class="emoji">🏀</div><h3>بسکتبال</h3></div>
        <div class="card"><div class="emoji">🏐</div><h3>والیبال</h3></div>
        <div class="card"><div class="emoji">🎾</div><h3>تنیس</h3></div>
        <div class="card"><div class="emoji">🐎</div><h3>اسب‌سواری</h3></div>
        <div class="card"><div class="emoji">⚔️</div><h3>شمشیربازی</h3></div>
    </div>
    <p style="margin-top:15px"><a href="index.html" style="color:#ffd700">🔙 برگشت</a></p>
</body>
</html>
