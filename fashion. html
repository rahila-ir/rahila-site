        <div class="fashion-card"><div class="emoji">👘</div><h3>مانتو</h3></div>
        <div class="fashion-card"><div class="emoji">👚</div><h3>شومیز</h3></div>
        <div class="fashion-card"><div class="emoji">👖</div><h3>شلوار</h3></div>
        <div class="fashion-card"><div class="emoji">🧥</div><h3>کت و دامن</h3></div>
        <div class="fashion-card"><div class="emoji">🤵</div><h3>کت و شلوار</h3></div>
    </div>

    <div class="section-title">👠 کفش و کیف</div>
    <div class="fashion-grid">
        <div class="fashion-card"><div class="emoji">👠</div><h3>کفش پاشنه بلند</h3></div>
        <div class="fashion-card"><div class="emoji">👟</div><h3>کفش اسپرت</h3></div>
        <div class="fashion-card"><div class="emoji">👢</div><h3>بوت</h3></div>
        <div class="fashion-card"><div class="emoji">👜</div><h3>کیف مجلسی</h3></div>
        <div class="fashion-card"><div class="emoji">🎒</div><h3>کوله پشتی</h3></div>
        <div class="fashion-card"><div class="emoji">👛</div><h3>کیف دستی</h3></div>
    </div>

    <div class="section-title">💄 مد و استایل</div>
    <div class="fashion-grid">
        <div class="fashion-card"><div class="emoji">✨</div><h3>ست کردن لباس</h3></div>
        <div class="fashion-card"><div class="emoji">🎨</div><h3>رنگ سال</h3></div>
        <div class="fashion-card"><div class="emoji">📸</div><h3>ژست عکاسی</h3></div>
        <div class="fashion-card"><div class="emoji">💍</div><h3>اکسسوری</h3></div>
        <div class="fashion-card"><div class="emoji">🧣</div><h3>شال و روسری</h3></div>
        <div class="fashion-card"><div class="emoji">🧤</div><h3>دستکش</h3></div>
    </div>

    <div class="section-title">💇 مدل مو و آرایش</div>
    <div class="fashion-grid">
        <div class="fashion-card"><div class="emoji">💇</div><h3>مدل کوتاهی مو</h3></div>
        <div class="fashion-card"><div class="emoji">💄</div><h3>میکاپ</h3></div>
        <div class="fashion-card"><div class="emoji">💅</div><h3>مدل ناخن</h3></div>
        <div class="fashion-card"><div class="emoji">👰</div><h3>شینیون عروس</h3></div>
        <div class="fashion-card"><div class="emoji">💆</div><h3>رنگ مو</h3></div>
        <div class="fashion-card"><div class="emoji">🦱</div><h3>فر مو</h3></div>
    </div>

    <div class="section-title">👓 اکسسوری</div>
    <div class="fashion-grid">
        <div class="fashion-card"><div class="emoji">👓</div><h3>عینک طبی</h3></div>
        <div class="fashion-card"><div class="emoji">🕶️</div><h3>عینک آفتابی</h3></div>
        <div class="fashion-card"><div class="emoji">⌚</div><h3>ساعت مچی</h3></div>
        <div class="fashion-card"><div class="emoji">💍</div><h3>انگشتر</h3></div>
        <div class="fashion-card"><div class="emoji">📿</div><h3>گردنبند</h3></div>
        <div class="fashion-card"><div class="emoji">💎</div><h3>گوشواره</h3></div>
    </div>

    <p style="margin-top:15px"><a href="index.html" style="color:#ffd700">🔙 برگشت به صفحه اصلی</a></p>
</body>
</html>
